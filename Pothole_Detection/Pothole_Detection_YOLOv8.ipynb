# Cell 3 — Imports
import os
import cv2
import numpy as np
import matplotlib.pyplot as plt
from ultralytics import YOLO
from IPython.display import Image, display

# Cell 4 — Download Dataset from Roboflow
from roboflow import Roboflow
rf = Roboflow(api_key="YOUR_API_KEY")
project = rf.workspace("roboflow-100").project("pothole-detection-dataset")
dataset = project.version(1).download("yolov8")

# Cell 5 — Explore Dataset
print("Dataset location:", dataset.location)
train_images = os.listdir(f"{dataset.location}/train/images")
print(f"Training images: {len(train_images)}")

# Show sample images
fig, axes = plt.subplots(1, 3, figsize=(15, 5))
for i, ax in enumerate(axes):
    img = cv2.imread(f"{dataset.location}/train/images/{train_images[i]}")
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    ax.imshow(img)
    ax.set_title(f"Sample {i+1}")
    ax.axis("off")
plt.suptitle("Sample Training Images", fontsize=14)
plt.tight_layout()
plt.show()

# Cell 6 — Train YOLOv8 Model
model = YOLO("yolov8n.pt")  # Load pretrained nano model

results = model.train(
    data=f"{dataset.location}/data.yaml",
    epochs=30,
    imgsz=640,
    batch=16,
    name="pothole_yolov8",
    patience=10,
    verbose=True
)

# Cell 7 — Evaluate Model
metrics = model.val()
print(f"mAP@50:      {metrics.box.map50:.4f}")
print(f"Precision:   {metrics.box.p.mean():.4f}")
print(f"Recall:      {metrics.box.r.mean():.4f}")

# Cell 8 — Plot Training Curves
import glob
results_img = glob.glob("runs/detect/pothole_yolov8/results.png")
if results_img:
    display(Image(filename=results_img[0]))

# Cell 9 — Run Inference on Test Images
best_model = YOLO("runs/detect/pothole_yolov8/weights/best.pt")

test_images = os.listdir(f"{dataset.location}/test/images")[:6]

fig, axes = plt.subplots(2, 3, figsize=(18, 10))
for ax, img_name in zip(axes.flatten(), test_images):
    img_path = f"{dataset.location}/test/images/{img_name}"
    preds = best_model.predict(img_path, conf=0.25, verbose=False)
    annotated = preds[0].plot()
    annotated = cv2.cvtColor(annotated, cv2.COLOR_BGR2RGB)
    ax.imshow(annotated)
    ax.set_title(f"Detections: {len(preds[0].boxes)}", fontsize=10)
    ax.axis("off")

plt.suptitle("YOLOv8 Pothole Detection — Test Results", fontsize=15)
plt.tight_layout()
plt.show()

